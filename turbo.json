{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".nvmrc", ".yarnrc.yml"],
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "build:android": {
      "env": ["ANDROID_HOME", "ORG_GRADLE_PROJECT_newArchEnabled"],
      "inputs": [
        "package.json",
        "android/**",
        "!android/build/**",
        "!android/.gradle/**",
        "src/**",
        "$TURBO_ROOT$/android/**",
        "!$TURBO_ROOT$/android/build/**",
        "!$TURBO_ROOT$/android/generated/**",
        "$TURBO_ROOT$/src/**",
        "$TURBO_ROOT$/cpp/**",
        "$TURBO_ROOT$/package.json"
      ],
      "outputs": []
    },
    "build:ios": {
      "env": [
        "RCT_NEW_ARCH_ENABLED",
        "RCT_REMOVE_LEGACY_ARCH",
        "RCT_USE_RN_DEP",
        "RCT_USE_PREBUILT_RNCORE"
      ],
      "inputs": [
        "package.json",
        "ios/**",
        "!ios/build/**",
        "!ios/Pods/**",
        "src/**",
        "$TURBO_ROOT$/ios/**",
        "!$TURBO_ROOT$/ios/build/**",
        "$TURBO_ROOT$/src/**",
        "$TURBO_ROOT$/cpp/**",
        "$TURBO_ROOT$/*.podspec",
        "$TURBO_ROOT$/package.json"
      ],
      "outputs": []
    }
  }
}
