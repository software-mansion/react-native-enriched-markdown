{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".nvmrc", ".yarnrc.yml"],
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "build:android": {
      "env": ["ANDROID_HOME", "ORG_GRADLE_PROJECT_newArchEnabled"],
      "inputs": [
        "package.json",
        "android/**",
        "!android/build/**",
        "!android/.gradle/**",
        "src/**",
        "$TURBO_ROOT$/packages/react-native-enriched-markdown/android/**",
        "!$TURBO_ROOT$/packages/react-native-enriched-markdown/android/build/**",
        "!$TURBO_ROOT$/packages/react-native-enriched-markdown/android/generated/**",
        "$TURBO_ROOT$/packages/react-native-enriched-markdown/src/**",
        "$TURBO_ROOT$/packages/core/cpp/**",
        "$TURBO_ROOT$/packages/react-native-enriched-markdown/package.json"
      ],
      "outputs": []
    },
    "build:ios": {
      "env": [
        "RCT_NEW_ARCH_ENABLED",
        "RCT_REMOVE_LEGACY_ARCH",
        "RCT_USE_RN_DEP",
        "RCT_USE_PREBUILT_RNCORE"
      ],
      "inputs": [
        "package.json",
        "ios/**",
        "!ios/build/**",
        "!ios/Pods/**",
        "src/**",
        "$TURBO_ROOT$/packages/react-native-enriched-markdown/ios/**",
        "!$TURBO_ROOT$/packages/react-native-enriched-markdown/ios/build/**",
        "$TURBO_ROOT$/packages/react-native-enriched-markdown/src/**",
        "$TURBO_ROOT$/packages/core/cpp/**",
        "$TURBO_ROOT$/packages/react-native-enriched-markdown/*.podspec",
        "$TURBO_ROOT$/packages/react-native-enriched-markdown/package.json"
      ],
      "outputs": []
    },
    "build:android-native": {
      "env": ["ANDROID_HOME"],
      "inputs": [
        "package.json",
        "app/**",
        "gradle/**",
        "$TURBO_ROOT$/packages/android-enriched-markdown/**",
        "!$TURBO_ROOT$/packages/android-enriched-markdown/**/build/**",
        "$TURBO_ROOT$/packages/core/cpp/**"
      ],
      "outputs": []
    },
    "test:android-native": {
      "env": ["ANDROID_HOME"],
      "inputs": [
        "package.json",
        "**/*.kt",
        "**/*.gradle",
        "gradle/**",
        "$TURBO_ROOT$/packages/core/cpp/**"
      ],
      "outputs": []
    },
    "lint:android-native": {
      "env": ["ANDROID_HOME"],
      "inputs": [
        "package.json",
        "**/*.kt",
        "**/*.gradle",
        "gradle/**"
      ],
      "outputs": []
    }
  }
}
