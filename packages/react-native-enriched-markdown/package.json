{
  "name": "react-native-enriched-markdown",
  "version": "0.7.4",
  "description": "Markdown Text component for React Native",
  "main": "./lib/module/index",
  "module": "./lib/module/index",
  "source": "./src/index.tsx",
  "types": "./lib/typescript/src/index.d.ts",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*",
    "app.plugin.js",
    "plugin",
    "docs"
  ],
  "scripts": {
    "build:wasm": "bash ../core/cpp/wasm/build.sh",
    "typecheck": "tsc",
    "lint-clang:ios": "find ios/ \\( -iname \"*.h\" -o -iname \"*.m\" -o -iname \"*.mm\" \\) | grep -v -e Pods -e build | xargs npx clang-format -i -n --Werror",
    "lint-clang:ios:fix": "find ios/ \\( -iname \"*.h\" -o -iname \"*.m\" -o -iname \"*.mm\" \\) | grep -v -e Pods -e build | xargs npx clang-format -i",
    "lint-clang:android": "find android/ \\( -iname \"*.h\" -o -iname \"*.cpp\" \\) | grep -v -e build | xargs npx clang-format -i -n --Werror",
    "lint-clang:android:fix": "find android/ \\( -iname \"*.h\" -o -iname \"*.cpp\" \\) | grep -v -e build | xargs npx clang-format -i",
    "lint-clang": "yarn lint-clang:ios && yarn lint-clang:android",
    "lint-clang:fix": "yarn lint-clang:ios:fix && yarn lint-clang:android:fix",
    "clean": "del-cli android/build lib plugin/build",
    "sync-md4c": "bash ../../scripts/fetch-md4c.sh",
    "prepack": "bash ../../scripts/prepare-npm-publish.sh prepack",
    "postpack": "bash ../../scripts/prepare-npm-publish.sh postpack",
    "build:plugin": "tsc -p plugin/tsconfig.build.json",
    "prepare": "bob build && yarn build:plugin"
  },
  "keywords": [
    "react-native",
    "expo",
    "ios",
    "android",
    "macos",
    "web",
    "markdown",
    "rich-editor"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/software-mansion/react-native-enriched-markdown.git",
    "directory": "packages/react-native-enriched-markdown"
  },
  "author": "Gregory Moskaliuk <mosckalyuck@gmail.com> (https://github.com/hryhoriiK97)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/software-mansion/react-native-enriched-markdown/issues"
  },
  "homepage": "https://enriched.swmansion.com/markdown",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "@expo/config-plugins": ">=50.0.0",
    "katex": ">=0.16.0",
    "react": "*",
    "react-native": "*"
  },
  "peerDependenciesMeta": {
    "@expo/config-plugins": {
      "optional": true
    },
    "katex": {
      "optional": true
    }
  },
  "devDependencies": {
    "@expo/config-plugins": "^55.0.6",
    "@react-native/babel-preset": "0.85.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.0",
    "clang-format": "^1.8.0",
    "del-cli": "^7.0.0",
    "react": "19.2.3",
    "react-native": "0.85.0",
    "react-native-builder-bob": "^0.41.0",
    "typescript": "^6.0.2"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "codegen",
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "EnrichedMarkdownTextSpec",
    "type": "components",
    "jsSrcsDir": "src",
    "outputDir": {
      "ios": "ios/generated",
      "android": "android/generated"
    },
    "android": {
      "javaPackageName": "com.swmansion.enriched.markdown"
    },
    "ios": {
      "components": {
        "EnrichedMarkdownText": {
          "className": "EnrichedMarkdownText"
        },
        "EnrichedMarkdown": {
          "className": "EnrichedMarkdown"
        },
        "EnrichedMarkdownTextInput": {
          "className": "EnrichedMarkdownTextInput"
        }
      }
    },
    "includesGeneratedCode": true
  },
  "create-react-native-library": {
    "type": "fabric-view",
    "languages": "kotlin-objc",
    "tools": [
      "eslint",
      "lefthook",
      "release-it"
    ],
    "version": "0.62.0"
  }
}
