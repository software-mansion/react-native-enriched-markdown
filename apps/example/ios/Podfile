ENV['RCT_NEW_ARCH_ENABLED'] = '1'

# Set to '0' to disable LaTeX math rendering and remove the iosMath dependency (~2.5 MB savings).
#ENV['ENRICHED_MARKDOWN_ENABLE_MATH'] = '0'

# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'EnrichedMarkdownExample' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Codegen output for third-party Fabric components (e.g. rnscreens, rnsvg) lives under
    # ios/build/generated/ios/ReactCodegen. CocoaPods may not symlink all component headers into
    # Pods/Headers/Public/ReactCodegen, which breaks angled imports like
    # <react/renderer/components/rnscreens/EventEmitters.h>.
    react_codegen_generated = '"$(PODS_ROOT)/../build/generated/ios/ReactCodegen"'
    installer.pods_project.targets.each do |target|
      next unless ['RNScreens', 'RNSVG'].include?(target.name)

      target.build_configurations.each do |cfg|
        existing = cfg.build_settings['HEADER_SEARCH_PATHS']
        next if existing.to_s.include?('build/generated/ios/ReactCodegen')

        if existing.nil? || existing == ''
          cfg.build_settings['HEADER_SEARCH_PATHS'] = "$(inherited) #{react_codegen_generated}"
        elsif existing.is_a?(Array)
          cfg.build_settings['HEADER_SEARCH_PATHS'] = existing + [react_codegen_generated]
        else
          cfg.build_settings['HEADER_SEARCH_PATHS'] = "#{existing} #{react_codegen_generated}"
        end
      end
    end
  end
end
